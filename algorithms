#include <iostream>
#include <vector>
#include <queue>
#include <algorithm>
#include <climits>

using namespace std;

// ==========================================
// DATA STRUCTURES
// ==========================================
struct Delivery { int id, deadline, priority; };
struct Item { int value, weight; };

// ==========================================
// MODULE 1: SORTING
// ==========================================
void merge(vector<Delivery>& arr, int l, int m, int r) {
    vector<Delivery> L(arr.begin() + l, arr.begin() + m + 1);
    vector<Delivery> R(arr.begin() + m + 1, arr.begin() + r + 1);
    int i = 0, j = 0, k = l;
    while (i < L.size() && j < R.size()) {
        if (L[i].deadline <= R[j].deadline) arr[k++] = L[i++];
        else arr[k++] = R[j++];
    }
    while (i < L.size()) arr[k++] = L[i++];
    while (j < R.size()) arr[k++] = R[j++];
}

void mergeSort(vector<Delivery>& arr, int l, int r) {
    if (l >= r) return;
    int m = l + (r - l) / 2;
    mergeSort(arr, l, m);
    mergeSort(arr, m + 1, r);
    merge(arr, l, m, r);
}

int partition(vector<Delivery>& arr, int low, int high) {
    int pivot = arr[high].priority;
    int i = low - 1;
    for (int j = low; j < high; j++) {
        if (arr[j].priority > pivot) {
            i++;
            swap(arr[i], arr[j]);
        }
    }
    swap(arr[i + 1], arr[high]);
    return i + 1;
}

void quickSort(vector<Delivery>& arr, int low, int high) {
    if (low < high) {
        int pi = partition(arr, low, high);
        quickSort(arr, low, pi - 1);
        quickSort(arr, pi + 1, high);
    }
}

// ==========================================
// MODULE 2: GRAPH (DIJKSTRA)
// ==========================================
void runDijkstra(int src, int n, const vector<vector<pair<int, int>>>& adj) {
    vector<int> dist(n, INT_MAX);
    priority_queue<pair<int, int>, vector<pair<int, int>>, greater<>> pq;
    dist[src] = 0;
    pq.push({0, src});

    while (!pq.empty()) {
        auto [d, u] = pq.top();
        pq.pop();
        if (d > dist[u]) continue;
        for (auto [v, w] : adj[u]) {
            if (dist[v] > dist[u] + w) {
                dist[v] = dist[u] + w;
                pq.push({dist[v], v});
            }
        }
    }
    cout << "Shortest distances from source " << src << ":\n";
    for (int i = 0; i < n; i++) cout << "To " << i << " = " << dist[i] << endl;
}

// ==========================================
// MODULE 3: GREEDY (FRACTIONAL KNAPSACK)
// ==========================================
bool cmp(Item a, Item b) {
    return (double)a.value / a.weight > (double)b.value / b.weight;
}

double fractionalKnapsack(int W, vector<Item> items) {
    sort(items.begin(), items.end(), cmp);
    double totalValue = 0.0;
    for (auto item : items) {
        if (W >= item.weight) {
            totalValue += item.value;
            W -= item.weight;
        } else {
            totalValue += item.value * ((double)W / item.weight);
            break;
        }
    }
    return totalValue;
}

// ==========================================
// MODULE 4: DP (0/1 KNAPSACK)
// ==========================================
int knapsack01(int W, const vector<int>& wt, const vector<int>& val, int n) {
    vector<vector<int>> dp(n + 1, vector<int>(W + 1, 0));
    for (int i = 1; i <= n; i++) {
        for (int w = 0; w <= W; w++) {
            if (wt[i - 1] <= w)
                dp[i][w] = max(dp[i - 1][w], val[i - 1] + dp[i - 1][w - wt[i - 1]]);
            else
                dp[i][w] = dp[i - 1][w];
        }
    }
    return dp[n][W];
}

// ==========================================
// MAIN EXECUTION
// ==========================================
int main() {
    // --- 1. Sorting Demo ---
    vector<Delivery> deliveries = {{1, 5, 2}, {2, 2, 5}, {3, 3, 1}, {4, 1, 4}};
    cout << "--- Sorting Module ---\n";
    mergeSort(deliveries, 0, deliveries.size() - 1);
    cout << "Sorted by Deadline:\n";
    for (auto d : deliveries) cout << "ID: " << d.id << " Deadline: " << d.deadline << endl;

    // --- 2. Graph Demo ---
    int n = 5;
    vector<vector<pair<int, int>>> adj(n);
    adj[0].push_back({1, 4}); adj[0].push_back({2, 1});
    adj[2].push_back({1, 2}); adj[1].push_back({3, 1});
    adj[2].push_back({3, 5}); adj[3].push_back({4, 3});
    cout << "\n--- Graph Module ---\n";
    runDijkstra(0, n, adj);

    // --- 3. Greedy Demo ---
    vector<Item> items = {{60, 10}, {100, 20}, {120, 30}};
    cout << "\n--- Greedy Module (Fractional) ---\n";
    cout << "Max Value: " << fractionalKnapsack(50, items) << endl;

    // --- 4. DP Demo ---
    vector<int> wt = {10, 20, 30};
    vector<int> val = {60, 100, 120};
    cout << "\n--- DP Module (0/1 Knapsack) ---\n";
    cout << "Max Value: " << knapsack01(50, wt, val, wt.size()) << endl;

    return 0;
}
